# Local state files
config/.usage.json
config/.auth-session.json
config/.setup-status.json
config/.blueprint-history.json

# Bridge server PID
.claude-bridge-pid

# Bridge error logs and notifications (runtime)
.bridge-errors.log
.bridge-errors.log.1
.bridge-notifications.json

# Claude Code local settings (secrets, API keys)
.claude/settings.local.json

# Environment variables (secrets)
.env
.env.local
.env.production

# Node modules
node_modules/

# Admin dashboard is safe to share (no secrets — uses bridge auth)
