# Article Engine Bridge Server — Environment Variables
# Copy this file to .env and fill in your values.
# All variables are optional — sensible defaults are embedded.

# Bridge server port (default: 19847)
BRIDGE_PORT=19847

# Set to "1" for JSON structured logging (default: plain text)
BRIDGE_LOG_JSON=0

# Supabase configuration (defaults are embedded in supabase-client.js)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (required for admin operations)
# NEVER commit this value. Keep it in .env only.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Node environment (used by some tooling)
# NODE_ENV=development
